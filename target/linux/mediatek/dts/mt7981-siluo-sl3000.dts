/dts-v1/;

#include "mt7981.dtsi"

/ {
	compatible = "siluo,sl3000", "mediatek,mt7981";
	model = "Siluo SL3000";

	chosen {
		stdout-path = &uart0;
		bootargs = "console=ttyS0,115200n8";
	};

	memory {
		device_type = "memory";
		reg = <0x40000000 0x20000000>; /* 512MiB */
	};

	leds {
		compatible = "gpio-leds";
		status {
			label = "status";
			gpios = <&gpio 12 GPIO_ACTIVE_LOW>;
		};
	};

	keys {
		compatible = "gpio-keys";
		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
		};
	};
};

/* eMMC 存储定义，含 Docker 分区 */
&mmc0 {
	status = "okay";

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		bootloader@0 {
			label = "bootloader";
			reg = <0x00000000 0x01000000>; /* 16MB */
			read-only;
		};

		firmware@1000000 {
			label = "firmware";
			reg = <0x01000000 0x20000000>; /* 512MB 固件区 */
		};

		factory@21000000 {
			label = "factory";
			reg = <0x21000000 0x01000000>; /* 16MB 校准区 */
		};

		docker@22000000 {
			label = "docker";
			reg = <0x22000000 0x280000000>; /* 10GB Docker 专用分区 */
		};
	};
};

&eth {
	status = "okay";
	/* TODO: 根据实际 PHY 拓扑补充 mdio/phy */
};

&wmac {
	status = "okay";
};
