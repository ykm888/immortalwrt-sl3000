#
# Target: MT7981 + SL3000 eMMC
#
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_sl_3000-emmc=y

#
# eMMC 驱动 + 分区工具
#
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-mmc-mtk=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blockd=y
CONFIG_PACKAGE_parted=y
# CONFIG_PARTED_READLINE is not set
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y

#
# WiFi 驱动（MT7981 必选）
#
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y
# CONFIG_PACKAGE_wpad-openssl is not set

#
# 160MHz 支持
#
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_crda=y

#
# LuCI 基础
#
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

#
# 网络基础
#
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_ipv6helper=y
# CONFIG_PACKAGE_xtables-nft is not set

#
# NAS（Samba4 + 文件系统）
#
CONFIG_PACKAGE_samba4-libs=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_SAMBA4_SERVER_NETBIOS=y
CONFIG_SAMBA4_SERVER_VFS=y
CONFIG_SAMBA4_SERVER_WSDD2=y
# CONFIG_SAMBA4_SERVER_AVAHI is not set
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_wsdd2=y

#
# 常用工具
#
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
# CONFIG_PACKAGE_htop is not set
# CONFIG_PACKAGE_nano is not set

#
# 性能优化
#
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-tcp-bbr=y

#
# LuCI 插件
#
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_tc=y
CONFIG_PACKAGE_luci-app-arpbind=y

#
# 安全增强
#
CONFIG_PACKAGE_luci-app-banip=y
CONFIG_PACKAGE_luci-app-ddns=y

#
# VPN 支持
#
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_luci-app-wireguard=y

#
# 构建日志 + 签名
#
CONFIG_BUILD_LOG=y
CONFIG_PACKAGE_usign=y

#
# 关闭 PPP
#
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_pppoe is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set

#
# 保留构建信息
#
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y
